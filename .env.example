# Google OAuth 2.0 Client ID (Web application type)
# Issue at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Taskchute spreadsheet ID (the long string in the sheet URL)
VITE_TASKCHUTE_SPREADSHEET_ID=

# Taskchute Google Calendar ID (e.g. c_xxxxxxxxxxxx@group.calendar.google.com)
VITE_TASKCHUTE_CALENDAR_ID=

# Optional: personal calendar to sync in read-only as "meeting" tasks
# (e.g. your own account email). Leave unset to disable meeting sync.
VITE_MEETING_CALENDAR_ID=
